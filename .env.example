# API — points to ArmadaCMS backend (required for most pages)
NEXT_PUBLIC_API_URL=https://cms.armada.nu # or http://localhost:8080 if running locally

# Optional: preview-only feature flag overrides (server-side)
# Applied only when VERCEL_ENV=preview.
# Merge order: default -> branch -> deployment -> vercel-flag-overrides cookie
# Example:
# FEATURE_FLAG_PREVIEW_OVERRIDES_JSON={"default":{"MAP_PAGE":true},"branches":{"feature/my-branch":{"EVENT_PAGE":false}},"deployments":{"armada-nu-git-feature-my-branch-armada-ths.vercel.app":{"EXHIBITOR_EVENTS":true}}}
FEATURE_FLAG_PREVIEW_OVERRIDES_JSON=

# Contentful CMS (only needed for blog/content pages)
CONTENTFUL_SPACE_ID=
CONTENTFUL_PREVIEW_TOKEN=
CONTENTFUL_DELIVERY_TOKEN=

# reCAPTCHA (only needed for exhibitor contact forms)
NEXT_PUBLIC_RECAPTCHA_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Slack webhooks (only needed for exhibitor form submissions)
SLACK_SALES_HOOK_URL=
SLACK_ORDER_HOOK_URL=
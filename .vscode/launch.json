{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frontend (Prod CMS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}",
      "env": {
        "NEXT_PUBLIC_API_URL": "https://cms.armada.nu"
      },
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Browser",
        "pattern": "- Local:\\s+(https?://[^\\s]+)"
      }
    },
    {
      "name": "Frontend (Local CMS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}",
      "env": {
        "NEXT_PUBLIC_API_URL": "http://localhost:8080"
      },
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Browser",
        "pattern": "- Local:\\s+(https?://[^\\s]+)"
      }
    },
    {
      "name": "Browser",
      "type": "editor-browser",
      "request": "launch",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
